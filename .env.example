# Base Sepolia (the live on-chain leg of the demo)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Deployer / relayer key. NEVER commit a real key. Fund via a Base Sepolia faucet.
DEPLOYER_PRIVATE_KEY=0xYOUR_TESTNET_KEY

# Deployed contract addresses (filled by contracts/base/script output)
FINALITY_REGISTRY_ADDRESS=
CRE_LEVEL3_RECEIVER_ADDRESS=
WORMHOLE_OUTCOME_RECEIVER_ADDRESS=
DEMO_PREDICTION_MARKET_ADDRESS=
WORMHOLE_CORE_ADDRESS=

# TxLINE (optional — the demo ships with a recorded deterministic fixture;
# a live TxLINE feed is not required to run it)
TXLINE_API_BASE_URL=
TXLINE_API_KEY=

# Solana (Level 4 source leg — simulated in this build; see README trust table)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
